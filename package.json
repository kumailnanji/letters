{
  "name": "@kumailnanji/letters",
  "version": "0.1.0",
  "description": "Animated handwritten text for React — Hershey layout + hand-tuned Bézier glyphs, driven by Framer Motion.",
  "license": "MIT",
  "author": "Kumail Nanji",
  "repository": {
    "type": "git",
    "url": "https://github.com/kumailnanji/letters.git"
  },
  "homepage": "https://github.com/kumailnanji/letters#readme",
  "bugs": {
    "url": "https://github.com/kumailnanji/letters/issues"
  },
  "keywords": [
    "react",
    "svg",
    "animation",
    "handwriting",
    "hershey",
    "framer-motion"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "fit-curve": "^0.2.0"
  },
  "peerDependencies": {
    "framer-motion": "^11 || ^12",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.12.0"
}
